{
  "name": "shipit",
  "version": "0.4.0",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "DO_NOT_TRACK=1 bun build --compile --minify ./index.ts --outfile ./build/shipit",
    "copy": "cp ./build/shipit /usr/local/bin/shipit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "postinstall": "simple-git-hooks",
    "preinstall": "bunx only-allow bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/groq": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@clack/prompts": "^1.6.0",
    "@linear/sdk": "^87.0.0",
    "@types/bun": "latest",
    "@types/node": "^25.9.4",
    "@types/stream-json": "^1.7.8",
    "ai": "^7.0.0",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "gpt-tokenizer": "^3.4.0",
    "simple-git": "^3.36.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.71.0",
    "simple-git-hooks": "^2.13.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
